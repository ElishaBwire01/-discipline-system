{
  "builds": [
    {
      "src": "disciplinary_program/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/"
    },
    {
      "src": "/(.*)",
      "dest": "disciplinary_program/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SECRET_KEY": "your-secret-key-here"
  }
}
